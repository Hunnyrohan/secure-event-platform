# Frontend build-time environment (Vite). Copy to `.env`.
# Only VITE_-prefixed vars are exposed to the client bundle.

# Google reCAPTCHA v2 (checkbox) SITE key. Leave blank to disable the CAPTCHA
# widget in dev (registration/login work without it). Must correspond to the
# backend's RECAPTCHA_SECRET_KEY. Google's public test site key (always passes):
#   VITE_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MUexfnk
VITE_RECAPTCHA_SITE_KEY=
