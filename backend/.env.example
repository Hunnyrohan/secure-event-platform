# ==========================================================================
# Secure Event Management Platform - Backend environment variables
# Copy to .env and replace every placeholder. NEVER commit the real .env.
# Generate secrets with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ==========================================================================

NODE_ENV=development
PORT=4000

# --- URLs -----------------------------------------------------------------
# Comma-separated allow-list of frontend origins for CORS.
CLIENT_ORIGIN=http://localhost:5173

# --- PostgreSQL -----------------------------------------------------------
PGHOST=localhost
PGPORT=5432
PGDATABASE=event_platform
PGUSER=event_app
PGPASSWORD=postgres
# Set to true only when connecting to a TLS-enabled DB (production).
PGSSL=false

# --- JWT ------------------------------------------------------------------
# Use two DIFFERENT 64+ char secrets. Rotate periodically.
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_a_DIFFERENT_64_char_random_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- AES-256-GCM application-level encryption -----------------------------
# 32-byte key as 64 hex chars. Used to encrypt OTP secrets / recovery codes.
# In production this MUST come from a secrets manager / KMS, not a file.
DATA_ENCRYPTION_KEY=replace_with_64_hex_chars_32_bytes

# --- MFA ------------------------------------------------------------------
# MFA now uses Google Authenticator (TOTP) via speakeasy/qrcode - no email or
# OTP config is required for the second factor. Recovery codes are AES-encrypted
# in the recovery_codes table.

# --- Account protection ---------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# --- Email --------------------------------------------------------------
# Email is only used for account-verification links now (MFA is TOTP).
# MAIL_DRIVER=log  -> writes the message (incl. the verification link) to the
#                     app log instead of sending it. Default in development, so
#                     the app is fully usable without a mail server.
# MAIL_DRIVER=smtp -> sends via the SMTP server below. Default in production.
MAIL_DRIVER=log
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Secure Events <no-reply@secure-events.local>"

# --- CAPTCHA (Google reCAPTCHA v2 checkbox) -------------------------------
# Protects registration + login from automated bots. Leave the keys blank in
# dev to disable CAPTCHA (auth flows work without it). Set both keys in
# production. The frontend needs the SITE key as VITE_RECAPTCHA_SITE_KEY
# (see frontend/.env.example). Google's public test keys (always pass) are:
#   site   = 6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MUexfnk
#   secret = 6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
CAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
